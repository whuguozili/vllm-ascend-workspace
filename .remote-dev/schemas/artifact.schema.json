{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "remote-dev.artifact_manifest.v1",
  "type": "object",
  "required": ["schema_version", "endpoint_id", "root", "file_count", "files"],
  "properties": {
    "schema_version": {"const": "remote-dev.artifact_manifest.v1"},
    "endpoint_id": {"type": "string"},
    "root": {"type": "string"},
    "is_dir": {"type": "boolean"},
    "file_count": {"type": "integer"},
    "total_bytes": {"type": "integer"},
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relpath", "path", "size", "sha256"],
        "properties": {
          "relpath": {"type": "string"},
          "path": {"type": "string"},
          "size": {"type": "integer"},
          "sha256": {"type": "string"}
        }
      }
    }
  },
  "additionalProperties": true
}
