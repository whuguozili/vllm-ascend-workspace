{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "remote-dev.result.v1",
  "type": "object",
  "required": ["schema_version", "tool", "invocation_id", "target", "outcome", "status", "summary"],
  "properties": {
    "schema_version": {"const": "remote-dev.result.v1"},
    "tool": {"type": "string"},
    "invocation_id": {"type": "string"},
    "target": {"type": "object"},
    "outcome": {"enum": ["success", "needs_input", "blocked", "failed", "timeout", "cancelled"]},
    "status": {"type": "string"},
    "summary": {"type": "string"},
    "preview": {"type": "object"},
    "refs": {"type": "object"},
    "artifacts": {"type": "array"},
    "changed_files": {"type": "array"},
    "warnings": {"type": "array"}
  },
  "additionalProperties": true
}
